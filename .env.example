# Copy this file to .env and fill in real values. Never commit .env (it holds secrets).

# Basic-auth credentials for the Clim4Cast upload API
API_USERNAME=your-username
API_PASSWORD=your-password

# CLIM4CAST_DRY_RUN — controls whether the upload step actually sends files.
#   True / (unset) / 1 / yes  -> DRY-RUN: skip the real upload (safe, for local development)
#   False / 0 / no            -> REAL upload to the site server (production only!)
CLIM4CAST_DRY_RUN=True